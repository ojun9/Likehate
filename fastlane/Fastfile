default_platform(:ios)

platform :ios do
   private_lane :app_store_connect_api do
      app_store_connect_api_key(
         key_id: "6972GX473A",
         issuer_id: "bc18c797-f1eb-42a9-a8f2-e90534387f68",
         key_filepath: File.expand_path("~/.private_keys/appstore_connect/AppStoreConnectKeyForFastlane.p8"),
         duration: 1200,
         in_house: false
      )
   end

   private_lane :deliver_configuration do |options|
      require "deliver"
      require "deliver/options"

      FastlaneCore::Configuration.create(
         Deliver::Options.available_options,
         {
            api_key: app_store_connect_api,
            app_identifier: "myfirst.Likehate",
            username: "eu.bkw7jdcpa2r@gmail.com",
            platform: "ios",
            force: true
         }.merge(options || {})
      )
   end

   private_lane :current_app_version do
      get_version_number(
         xcodeproj: "Likehate.xcodeproj",
         target: "Likehate"
      )
   end

   private_lane :app_review_submission_information do
      {
         export_compliance_uses_encryption: false,
         add_id_info_uses_idfa: true,
         add_id_info_serves_ads: true,
         add_id_info_tracks_install: false,
         add_id_info_tracks_action: false,
         add_id_info_limits_tracking: true
      }
   end

   desc "App Store Connectのmetadataを取得"
   lane :download_metadata do
      require "deliver/setup"

      options = deliver_configuration
      options.load_configuration_file("Deliverfile")
      Deliver::Runner.new(options)

      containing = FastlaneCore::Helper.fastlane_enabled_folder_path
      path = options[:metadata_path] || File.join(containing, "metadata")
      app = Deliver.cache[:app]
      platform = Spaceship::ConnectAPI::Platform.map(options[:platform])
      version = app.get_latest_app_store_version(platform: platform)

      if options[:app_version].to_s.length > 0
         version = app.get_live_app_store_version(platform: platform) if version.version_string != options[:app_version]
         if version.nil? || version.version_string != options[:app_version]
            UI.user_error!("Neither the current nor live version match specified app_version \"#{options[:app_version]}\"")
         end
      end

      Deliver::Setup.new.generate_metadata_files(app, version, path, options)
   end

   desc "App Store Connectのscreenshotsを取得"
   lane :download_screenshots do |lane_options|
      require "deliver/download_screenshots"

      use_live_version = lane_options.key?(:use_live_version) ? lane_options[:use_live_version] : true
      options = deliver_configuration(use_live_version: use_live_version)
      options.load_configuration_file("Deliverfile")
      Deliver::Runner.new(options, skip_version: true)

      containing = FastlaneCore::Helper.fastlane_enabled_folder_path
      path = options[:screenshots_path] || File.join(containing, "screenshots")
      Deliver::DownloadScreenshots.run(options, path)
   end

   desc "App Store Connectのmetadataとscreenshotsをまとめて反映"
   lane :store_assets do |lane_options|
      app_version = lane_options[:app_version]

      upload_to_app_store(
         api_key: app_store_connect_api,
         app_version: app_version,
         skip_binary_upload: true,
         submit_for_review: false,
         overwrite_screenshots: true,
         run_precheck_before_submit: false,
         force: true
      )
   end

   desc "処理済みbuildをApp Store Connectの編集バージョンに紐付け"
   lane :select_app_store_build do |lane_options|
      require "fastlane_core/build_watcher"

      app_version = lane_options[:app_version] || current_app_version
      build_number = lane_options[:build_number]

      app_store_connect_api

      app = Spaceship::ConnectAPI::App.find("myfirst.Likehate")
      UI.user_error!("Could not find app with app identifier 'myfirst.Likehate'") unless app

      platform = Spaceship::ConnectAPI::Platform.map("ios")
      version = app.get_edit_app_store_version(platform: platform)
      UI.user_error!("Editable App Store version not found for iOS") unless version
      if version.version_string != app_version
         UI.user_error!("Editable App Store version is #{version.version_string}, expected #{app_version}")
      end

      build =
         if build_number
            UI.message("Selecting existing build number #{build_number} for #{app_version}...")
            Spaceship::ConnectAPI::Build.all(
               app_id: app.id,
               version: app_version,
               build_number: build_number,
               platform: platform
            ).first
         else
            UI.message("Waiting for the latest processed build for #{app_version}...")
            FastlaneCore::BuildWatcher.wait_for_build_processing_to_be_complete(
               app_id: app.id,
               platform: platform,
               app_version: app_version,
               poll_interval: 15,
               return_when_build_appears: false,
               return_spaceship_testflight_build: false,
               select_latest: true
            )
         end

      UI.user_error!("Build not found for #{app_version}") unless build

      version.select_build(build_id: build.id)
      UI.success("Selected build #{build.app_version} (#{build.version}) for App Store version #{version.version_string}")
   end

   desc "App Store Connectの編集バージョンを審査提出"
   lane :submit_app_store_review do |lane_options|
      app_version = lane_options[:app_version] || current_app_version
      build_number = lane_options[:build_number] || "latest"

      upload_to_app_store(
         api_key: app_store_connect_api,
         app_version: app_version,
         build_number: build_number,
         skip_binary_upload: true,
         skip_metadata: true,
         skip_screenshots: true,
         submit_for_review: true,
         run_precheck_before_submit: false,
         submission_information: app_review_submission_information,
         force: true
      )
   end

   desc "リリース用IPAを生成してApp Store Connectへアップロード"
   lane :release_upload do |lane_options|
      ipa_path = "./build/Likehate.ipa"
      app_version = lane_options[:app_version] || current_app_version
      automatic_signing_xcargs = [
         "-allowProvisioningUpdates",
         "-authenticationKeyPath #{File.expand_path("~/.private_keys/appstore_connect/AppStoreConnectKeyForFastlane.p8")}",
         "-authenticationKeyID 6972GX473A",
         "-authenticationKeyIssuerID bc18c797-f1eb-42a9-a8f2-e90534387f68"
      ].join(" ")

      build_app(
         scheme: "Likehate",
         export_method: "app-store",
         output_directory: "./build",
         output_name: "Likehate.ipa",
         export_xcargs: automatic_signing_xcargs,
         export_options: {
            signingStyle: "automatic"
         }
      )

      upload_to_app_store(
         api_key: app_store_connect_api,
         app_version: app_version,
         ipa: ipa_path,
         submit_for_review: false,
         run_precheck_before_submit: false,
         force: true
      )

      select_app_store_build(
         app_version: app_version,
         build_number: lane_options[:build_number]
      )
   end
end
